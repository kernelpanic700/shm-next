# =============================================================================
# shm-next — Environment Variables
# =============================================================================
# Скопируйте этот файл как .env и заполните значениями

# === Приложение ===
APP_NAME=shm-next
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8001
WORKERS=4
RELOAD=true

# === Безопасность ===
SECRET_KEY=your-super-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_PHONE=+79990000000
# Prefer ADMIN_PASSWORD_HASH generated with app.infrastructure.auth.password.hash_password().
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
ALLOWED_HOSTS=*

# === База данных (Non-standard port: 15432) ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:15432/shm
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# === Redis (Non-standard port: 16379) ===
REDIS_URL=redis://localhost:16379/0
REDIS_CACHE_TTL=300

# === Taskiq ===
TASKIQ_BROKER_URL=redis://localhost:16379/1
TASKIQ_RESULT_BACKEND=redis://localhost:16379/2

# === Frontend Ports ===
CLIENT_PORT=3001
ADMIN_PORT=3002
TASKIQ_MAX_RETRIES=10
TASKIQ_RETRY_DELAY=3

# === Биллинг ===
BILLING_CYCLE_DAY=1
BILLING_BATCH_SIZE=100
BILLING_CHECK_INTERVAL=3600
DEFAULT_CURRENCY=RUB

# === Rate Limiting ===
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_API=200/minute

# === Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
EMAIL_FROM=noreply@shm.local

# === SMS ===
SMS_API_URL=https://api.sms-provider.com/send
SMS_API_KEY=your-sms-api-key
SMS_SENDER=SHM

# === OpenTelemetry ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=shm-next

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=
