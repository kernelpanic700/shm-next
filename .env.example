# =============================================================================
# shm-next — Environment Variables
# =============================================================================
# Скопируйте этот файл как .env и заполните значениями

# === Приложение ===
APP_NAME=shm-next
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4
RELOAD=true

# === Безопасность ===
SECRET_KEY=your-super-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_HOSTS=*

# === База данных ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/shm
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# === Redis ===
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# === Taskiq ===
TASKIQ_BROKER_URL=redis://localhost:6379/1
TASKIQ_RESULT_BACKEND=redis://localhost:6379/2
TASKIQ_MAX_RETRIES=10
TASKIQ_RETRY_DELAY=3

# === Биллинг ===
BILLING_CYCLE_DAY=1
BILLING_BATCH_SIZE=100
BILLING_CHECK_INTERVAL=3600
DEFAULT_CURRENCY=RUB

# === Rate Limiting ===
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_API=200/minute

# === Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@shm.local

# === Observability ===
LOG_LEVEL=INFO
SENTRY_DSN=

# === Frontend ===
NUXT_PUBLIC_API_URL=http://localhost:8000